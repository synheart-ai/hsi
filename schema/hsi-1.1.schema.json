{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://raw.githubusercontent.com/synheart-ai/hsi/main/schema/hsi-1.1.schema.json",
    "title": "Human State Interface (HSI) 1.1 - Revised",
    "type": "object",
    "additionalProperties": false,

    "$comment": "HSI is a contract-only interface. This schema is Draft 2020-12. Some reference-integrity constraints (e.g., windows keys matching window_ids, evidence_source_ids referencing meta.provenance.source_ids) cannot be fully enforced in pure JSON Schema and MUST be enforced out-of-band for HSI-VALIDATE-STRICT compliance.",

    "required": [
      "hsi_version",
      "observed_at_utc",
      "computed_at_utc",
      "producer",
      "window_ids",
      "windows",
      "privacy"
    ],

    "properties": {
      "hsi_version": { "type": "string", "const": "1.1" },

      "observed_at_utc": {
        "type": "string",
        "format": "date-time",
        "$comment": "Event-time: the human state time (typically aligns with the latest window end)."
      },

      "computed_at_utc": {
        "type": "string",
        "format": "date-time",
        "$comment": "Processing-time: when this payload was produced. Must be >= observed_at_utc (enforced out-of-band unless validator supports format comparisons)."
      },

      "producer": { "$ref": "#/$defs/producer" },

      "window_ids": {
        "type": "array",
        "minItems": 1,
        "uniqueItems": true,
        "items": { "$ref": "#/$defs/id" }
      },

      "windows": {
        "type": "object",
        "minProperties": 1,
        "propertyNames": { "$ref": "#/$defs/id" },
        "additionalProperties": { "$ref": "#/$defs/window" },
        "$comment": "HSI-VALIDATE-STRICT: windows object keys MUST be a subset of /window_ids, and every id in /window_ids MUST exist as a key in /windows."
      },

      "axes": { "$ref": "#/$defs/axes" },

      "embeddings": {
        "type": "array",
        "items": { "$ref": "#/$defs/embedding" }
      },

      "privacy": { "$ref": "#/$defs/privacy" },

      "meta": {
        "type": "object",
        "properties": {
          "provenance": { "$ref": "#/$defs/provenance" }
        },
        "$comment": "meta.provenance is the canonical place for source tracking, engine details, equation IDs, baseline status, and provider lists. Other meta keys are unconstrained."
      }
    },

    "$defs": {
      "id": {
        "type": "string",
        "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._-]{0,63}$"
      },

      "score01": {
        "type": "number",
        "minimum": 0,
        "maximum": 1
      },

      "producer": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "version"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "version": { "type": "string", "minLength": 1 },
          "instance_id": { "type": "string", "format": "uuid" }
        }
      },

      "window": {
        "type": "object",
        "additionalProperties": false,
        "required": ["start_utc", "end_utc"],
        "properties": {
          "start_utc": { "type": "string", "format": "date-time" },
          "end_utc": { "type": "string", "format": "date-time" },
          "label": { "type": "string" },
          "aggregation": {
            "type": "string",
            "enum": ["instant", "windowed", "cumulative"]
          }
        },
        "$comment": "HSI-VALIDATE-STRICT: window.end_utc MUST be >= window.start_utc (out-of-band unless validator supports format comparisons)."
      },

      "direction": {
        "type": "string",
        "enum": ["higher_is_more", "higher_is_less", "bidirectional"]
      },

      "axis_reading": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "value", "confidence", "direction", "window_ids", "evidence_source_ids"],
        "properties": {
          "name": { "type": "string" },
          "value": {
            "type": ["number", "null"],
            "$comment": "value MAY be null when a producer cannot compute a reading due to access-control, missing sources, or other constraints. Consumers MUST NOT interpret null as zero; explanation should be provided in meta."
          },
          "confidence": { "$ref": "#/$defs/score01" },
          "direction": { "$ref": "#/$defs/direction" },
          "inference_mode": {
            "type": "string",
            "enum": ["deterministic", "probabilistic", "composite"]
          },
          "model_id": { "type": "string" },
          "window_ids": {
            "type": "array",
            "items": { "$ref": "#/$defs/id" },
            "$comment": "window_ids entries SHOULD reference declared ids in /window_ids. Cross-reference validation enforced out-of-band."
          },
          "evidence_source_ids": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "$ref": "#/$defs/id",
              "$comment": "entries SHOULD reference meta.provenance.source_ids. Cross-reference validation enforced out-of-band."
            }
          }
        }
      },

      "axes_domain": {
        "type": "array",
        "items": { "$ref": "#/$defs/axis_reading" }
      },

      "axes": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "physiological": { "$ref": "#/$defs/axes_domain" },
          "engagement": { "$ref": "#/$defs/axes_domain" },
          "behavior": { "$ref": "#/$defs/axes_domain" },
          "context": { "$ref": "#/$defs/axes_domain" }
        }
      },

      "source": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "quality", "degraded"],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "sensor",
              "app",
              "self_report",
              "observer",
              "derived",
              "other"
            ]
          },
          "quality": { "$ref": "#/$defs/score01" },
          "degraded": { "type": "boolean" },
          "notes": { "type": "string" }
        }
      },

      "provenance": {
        "type": "object",
        "properties": {
          "source_ids": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "$ref": "#/$defs/id" }
          },
          "sources": {
            "type": "object",
            "minProperties": 1,
            "propertyNames": { "$ref": "#/$defs/id" },
            "additionalProperties": { "$ref": "#/$defs/source" },
            "$comment": "HSI-VALIDATE-STRICT: sources keys MUST match source_ids."
          },
          "baseline_status": { "type": "string" },
          "providers": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": { "type": "string" },
                "version": { "type": "string" }
              }
            }
          },
          "equation_id": { "type": "string" },
          "merge_rule_id": { "type": "string" },
          "engine": { "type": "string" },
          "engine_version": { "type": "string" }
        },
        "allOf": [
          {
            "$comment": "If one of sources/source_ids exists, require the other.",
            "if": { "required": ["sources"] },
            "then": { "required": ["source_ids"] }
          },
          {
            "if": { "required": ["source_ids"] },
            "then": { "required": ["sources"] }
          }
        ]
      },

      "embedding": {
        "type": "object",
        "additionalProperties": false,
        "required": ["window_ids", "dims", "encoding", "vector"],
        "properties": {
          "window_ids": {
            "type": "array",
            "items": { "$ref": "#/$defs/id" },
            "$comment": "embedding.window_ids entries SHOULD reference /window_ids. Cross-reference validation enforced out-of-band."
          },
          "dims": { "type": "integer", "minimum": 1 },
          "space": { "type": "string" },
          "encoding": {
            "type": "string",
            "enum": ["float32", "float64", "fp16", "int8"]
          },
          "vector": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "number" },
            "$comment": "Include only when privacy allows."
          },
          "vector_hash": {
            "type": "string",
            "minLength": 1,
            "$comment": "Recommended even if vector is present (e.g., sha256:...)."
          }
        }
      },

      "privacy": {
        "type": "object",
        "additionalProperties": false,
        "required": ["contains_pii"],
        "properties": {
          "contains_pii": { "const": false },
          "consent": {
            "type": "string",
            "enum": ["none", "implicit", "explicit"]
          },
          "purposes": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true
          },
          "raw_biosignals_allowed": { "type": "boolean" },
          "derived_metrics_allowed": { "type": "boolean" }
        }
      }
    }
  }
