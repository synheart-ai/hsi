{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/synheart-ai/hsi/main/schema/hsi-1.2.schema.json",
  "title": "Human State Interface (HSI) 1.2",
  "type": "object",
  "additionalProperties": false,

  "$comment": "HSI 1.2: Restores 1.1 structure (windows in root/meta, start_utc/end_utc) while adopting 1.2 logic (refined inference_mode, 1.2 privacy, and 'score' naming). HSI is a contract-only interface. Some reference-integrity constraints MUST be enforced out-of-band for HSI-VALIDATE-STRICT compliance.",

  "required": [
    "hsi_version",
    "observed_at_utc",
    "computed_at_utc",
    "producer",
    "windows",
    "privacy"
  ],

  "properties": {
    "hsi_version": { 
      "type": "string", 
      "const": "1.2" 
    },

    "observed_at_utc": {
      "type": "string",
      "format": "date-time",
      "$comment": "Event-time: the human state time (typically aligns with the latest window end)."
    },

    "computed_at_utc": {
      "type": "string",
      "format": "date-time",
      "$comment": "Processing-time: when this payload was produced. Must be >= observed_at_utc (enforced out-of-band unless validator supports format comparisons)."
    },

    "producer": { "$ref": "#/$defs/producer" },

    "windows": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": { "$ref": "#/$defs/id" },
      "additionalProperties": { "$ref": "#/$defs/window" },
      "$comment": "Map keys are the authoritative window IDs. axis_reading.window_ids and embedding.window_ids SHOULD reference these keys."
    },

    "axes": { "$ref": "#/$defs/axes" },

    "embeddings": {
      "type": "array",
      "items": { "$ref": "#/$defs/embedding" }
    },

    "privacy": { "$ref": "#/$defs/privacy" },

    "meta": {
      "type": "object",
      "properties": {
        "provenance": { "$ref": "#/$defs/provenance" }
      },
      "$comment": "meta may include provenance and other producer-defined keys. meta.provenance is the canonical place for source tracking in this version."
    }
  },

  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._-]{0,63}$"
    },

    "score01": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },

    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "instance_id": { "type": "string", "format": "uuid" }
      }
    },

    "window": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start_utc", "end_utc"],
      "properties": {
        "start_utc": { "type": "string", "format": "date-time" },
        "end_utc": { "type": "string", "format": "date-time" },
        "label": { "type": "string" }
      },
      "$comment": "HSI-VALIDATE-STRICT: window.end_utc MUST be >= window.start_utc (out-of-band unless validator supports format comparisons)."
    },

    "direction": {
      "type": "string",
      "enum": ["higher_is_more", "higher_is_less", "bidirectional"]
    },

    "inference_mode": {
      "type": "string",
      "enum": [
        "probabilistic_model",
        "deterministic_rule",
        "external_provider",
        "composite"
      ],
      "$comment": "probabilistic_model: learned/ensemble. deterministic_rule: formulas/rulepacks. external_provider: third-party or OS facts. composite: merged multi-source."
    },

    "axis_reading": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name", 
        "score", 
        "confidence", 
        "direction", 
        "window_ids", 
        "evidence_source_ids",
        "inference_mode",
        "model_id"
      ],
      "properties": {
        "name": { "type": "string" },
        "score": {
          "anyOf": [{ "$ref": "#/$defs/score01" }, { "type": "null" }],
          "$comment": "score MAY be null when a producer cannot compute a reading; consumers MUST NOT treat null as zero."
        },
        "confidence": { "$ref": "#/$defs/score01" },
        "direction": { "$ref": "#/$defs/direction" },
        "inference_mode": { "$ref": "#/$defs/inference_mode" },
        "model_id": { 
          "type": "string",
          "minLength": 1
        },
        "source_tier": { "type": "integer" },
        "window_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/id" },
          "$comment": "entries SHOULD reference keys in /windows."
        },
        "evidence_source_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": { 
            "$ref": "#/$defs/id",
            "$comment": "entries SHOULD reference keys in meta.provenance.sources."
          }
        },
        "notes": { "type": "string" }
      }
    },

    "axes_domain": {
      "type": "array",
      "items": { "$ref": "#/$defs/axis_reading" }
    },

    "axes": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "physiological": { "$ref": "#/$defs/axes_domain" },
        "engagement": { "$ref": "#/$defs/axes_domain" },
        "behavior": { "$ref": "#/$defs/axes_domain" },
        "context": { "$ref": "#/$defs/axes_domain" },
        "emotion": { "$ref": "#/$defs/axes_domain" }
      }
    },

    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "quality", "degraded"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["sensor", "app", "self_report", "observer", "derived", "other"]
        },
        "quality": { "$ref": "#/$defs/score01" },
        "degraded": { "type": "boolean" },
        "notes": { "type": "string" }
      }
    },

    "provenance": {
      "type": "object",
      "properties": {
        "sources": {
          "type": "object",
          "minProperties": 1,
          "propertyNames": { "$ref": "#/$defs/id" },
          "additionalProperties": { "$ref": "#/$defs/source" },
          "$comment": "Map keys are the authoritative source IDs. evidence_source_ids on axis_reading SHOULD reference these keys."
        },
        "baseline_status": { "type": "string" },
        "providers": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "version": { "type": "string" }
            }
          }
        },
        "engine": { "type": "string" },
        "engine_version": { "type": "string" }
      }
    },

    "embedding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["window_id", "dimension", "encoding", "confidence"],
      "properties": {
        "window_id": { 
          "$ref": "#/$defs/id",
          "$comment": "SHOULD reference a key in /windows."
        },
        "vector": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "number" },
          "$comment": "Include only when privacy allows."
        },
        "vector_hash": { 
          "type": "string",
          "minLength": 1,
          "$comment": "Recommended even if vector is present."
        },
        "dimension": { "type": "integer", "minimum": 1 },
        "encoding": {
          "type": "string",
          "enum": ["float32", "float64", "fp16", "int8"]
        },
        "confidence": { "$ref": "#/$defs/score01" },
        "model": { "type": "string" }
      },
      "allOf": [
        {
          "anyOf": [{ "required": ["vector"] }, { "required": ["vector_hash"] }]
        }
      ]
    },

    "privacy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contains_pii",
        "raw_biosignals_allowed",
        "derived_metrics_allowed"
      ],
      "properties": {
        "contains_pii": { "const": false },
        "raw_biosignals_allowed": { "type": "boolean" },
        "derived_metrics_allowed": { "type": "boolean" },
        "embedding_allowed": { "type": "boolean", "default": false },
        "consent": {
          "type": "string",
          "enum": ["none", "implicit", "explicit"]
        },
        "purposes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "notes": { "type": "string" }
      }
    }
  }
}